# Copy this file to .env and fill in your actual values
# .env file is gitignored and used for local development only

# Hugging Face token (for gated models like DINOv3)
HF_TOKEN=hf_your_token_here

# Kaggle API credentials (optional, for local testing)
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_api_key

# -----------------------------------------------------------------
# Redis Cache (Phase 1)
# -----------------------------------------------------------------
# Redis server URL. Default: local Redis on port 6379
# Docker: docker run -d --name redis-cache -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379/0

# How long to keep search results in cache (seconds). Default: 3600 (1 hour)
REDIS_CACHE_TTL=3600

# How long to keep text embeddings in cache (seconds). Default: 86400 (24 hours)
# Embeddings are expensive to compute so we keep them longer
REDIS_EMBEDDING_TTL=86400
